---
import BaseMeta from "@/components/BaseMeta.astro";
import { SITE_TITLE } from "@/consts";
import { useTranslations, LOCALES, type Lang } from "@/i18n";
import CommonBody from "@/layouts/CommonBody.astro";
import "@/styles/blog.less";

const t = useTranslations(Astro.currentLocale as Lang);
const locale = Astro.currentLocale as Lang;
const { data } = Astro.props;

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    mainEntityOfPage: Astro.url,
    headline: data.title,
    image: Astro.site?.toString().slice(0, -1) + data.cover.src,
    datePublished: data.date.toISOString(),
    dateModified: data.updatedDate
      ? data.updatedDate.toISOString()
      : data.date.toISOString(),
    // たまにエラーになるのはバグ?
    author: {
      "@type": "Person",
      name: "Akira HIRATA",
    },
    publisher: {
      "@type": "Organization",
      name: t(SITE_TITLE),
      logo: {
        "@type": "ImageObject",
        url: `${Astro.site}img/logo.svg`,
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "HOME",
        item: Astro.site,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "BLOG",
        item: `${Astro.site}blog/`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: data.title,
        item: Astro.url,
      },
    ],
  },
]);
---

<!--

  Source Code:
  https://github.com/psephopaiktes/hira.page

-->
<html lang={LOCALES[locale].lang || locale} dir={LOCALES[locale].dir || null}>
  <head prefix="og: https://ogp.me/ns#">
    <BaseMeta
      title={`${data.title}｜${t(SITE_TITLE)}`}
      description={data.description}
    />

    <!-- OGP -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@psephopaiktes" />

    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={data.title} />
    <meta property="og:site_name" content={t(SITE_TITLE)} />
    <meta property="og:description" content={data.description} />
    <meta
      property="og:image"
      content={Astro.site?.toString().slice(0, -1) + data.cover.src}
    />
    <meta
      property="og:image:url"
      content={Astro.site?.toString().slice(0, -1) + data.cover.src}
    />
    <meta property="og:locale" content={LOCALES[locale].lang || locale} />
    <meta property="og:type" content="article" />

    <!-- Redirect TODOi18n -->
    {
      data.redirect && (
        <>
          <meta http-equiv="refresh" content={`0; url=${data.redirect}`} />
          <link rel="canonical" href={data.redirect} />
        </>
      )
    }

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={schema} />

    <style is:inline set:html={data.customCSS ?? ""}></style>
  </head>

  <CommonBody>
    <slot />
  </CommonBody>

  <script>
    const links = document.getElementsByTagName("a");

    for (const link of links) {
      link.hostname !== location.hostname &&
        link.setAttribute("target", "_blank");
    }
  </script>
</html>
