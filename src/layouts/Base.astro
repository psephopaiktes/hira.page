---
import BaseMeta from "@/components/BaseMeta.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";
import CommonBody from "@/layouts/CommonBody.astro";
import { useTranslations, LOCALES, type Lang } from "@/i18n";

const t = useTranslations(Astro.currentLocale as Lang);
const locale = Astro.currentLocale as Lang;
let { title, description = t(SITE_DESCRIPTION) } = Astro.props;
title = title ? `${title}｜${t(SITE_TITLE)}` : t(SITE_TITLE);
---

<!--

  Source Code:
  https://github.com/psephopaiktes/hira.page

-->
<html lang={LOCALES[locale].lang || locale} dir={LOCALES[locale].dir || null}>
  <head prefix="og: https://ogp.me/ns#">
    <BaseMeta title={title} description={description} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content={t(SITE_TITLE)} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={Astro.site + "img/meta/ogp.png"} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:locale" content={LOCALES[locale].lang || locale} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@psephopaiktes" />
  </head>

  <CommonBody>
    <slot />
  </CommonBody>

  <script>
    document.addEventListener(
      "astro:page-load",
      () => {
        const elements = document.querySelectorAll("[data-inview]");
        if (!elements) return;

        function checkInView() {
          elements.forEach((el) => {
            const inView =
              el.getBoundingClientRect().top <= window.innerHeight - 48;
            if (inView) {
              el.classList.add("show");
            } else {
              el.classList.remove("show");
            }
          });
        }

        window.addEventListener("scroll", checkInView);
        checkInView();
      },
      { once: false },
    );
  </script>
</html>
