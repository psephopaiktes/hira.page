---
import { loadCollection } from "@/components/loadCollection.ts";
import { type Lang } from "@/i18n";
import Base from "@/layouts/Base.astro";
import "@/styles/blog.css";
import { Picture } from "astro:assets";
import { render } from "astro:content";

const locale = Astro.currentLocale as Lang;

export async function getStaticPaths() {
  const worksCollection = await loadCollection("works");

  return worksCollection.posts.map((post) => {
    const [lang, ...id] = post.id.split("/");
    return {
      params: { lang, id: id.join("/") },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title}>
  <Picture
    class="cover"
    formats={["avif"]}
    widths={[480, 768, 1280]}
    src={post.data.cover}
    alt={post.data.title}
  />

  <header class="l-content">
    <h1>{post.data.title}</h1>
    {
      post.data.url && (
        <a href={post.data.url} target="_blank">
          <svg-icon src="/img/icon/open.svg" class="u-iconInText" />
          {post.data.url}
        </a>
      )
    }
    <time datetime={post.data.date.toISOString()}>
      {post.data.date.getFullYear()}
    </time>
    <p>{post.data.description}</p>

    <ul>
      {
        post.data.tags.map((tag) => (
          <li>
            <a class="c-tag" href={`/${locale}/works/tag=${tag}/`}>
              <svg-icon src="/img/icon/tag.svg" />
              {tag}
            </a>
          </li>
        ))
      }
    </ul>
  </header>

  <div class="l-content content">
    <Content />
  </div>
</Base>

<style>
  .cover {
    display: block;
    border-radius: 8px;
    border: 1px solid rgb(from var(--color-main) r g b / 0.05);
    margin: 64px 64px 0;
    width: calc(100% - 128px);
    background: var(--color-placeholder);
    @media (width < 1280px) {
      margin: 0;
      width: 100%;
      border-radius: 24px 24px 0 0;
      border-width: 0 0 1px;
    }
    @media (width < 480px) {
      border-radius: 0;
    }
  }

  header {
    h1 {
      margin-block-start: 32px;
      font-size: 2em;
      @media (width < 1024px) {
        margin-block-start: 24px;
      }
      @media (width < 640px) {
        margin-block-start: 20px;
      }
    }

    > a {
      display: block;
      margin-block-start: 8px;
      color: var(--color-theme);
    }

    time {
      display: block;
      font-size: 0.9em;
      margin-block-start: 16px;
      color: rgb(from var(--color-main) r g b / 0.6);
    }

    > p {
      font-size: 0.9em;
      margin-block-start: 4px;
    }

    ul {
      display: flex;
      margin-block-start: 18px;
      gap: 6px;
    }
  }

  .content,
  .content :global(h2) {
    margin-block-start: 48px;
    @media (width < 1024px) {
      margin-block-start: 32px;
    }
    @media (width < 640px) {
      margin-block-start: 24px;
    }
  }
</style>
