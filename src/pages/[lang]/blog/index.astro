---
import BlogHeader from "@/components/Blog/Header.astro";
import BlogList from "@/components/Blog/List.astro";
import { loadCollection } from "@/components/loadCollection.ts";
import { getLocaleParams, type Lang } from "@/i18n";
import Base from "@/layouts/Base.astro";

const locale = Astro.currentLocale as Lang;
const blogCollection = await loadCollection("blog", locale);

export const getStaticPaths = () => getLocaleParams(import.meta.url);
---

<Base title="BLOG">
  <div class="l-content">
    <BlogHeader />
    <BlogList posts={blogCollection.posts} />
  </div>
</Base>
