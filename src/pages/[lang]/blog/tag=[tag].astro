---
import BlogHeader from "@/components/Blog/Header.astro";
import BlogList from "@/components/Blog/List.astro";
import { loadCollection } from "@/components/loadCollection.ts";
import Base from "@/layouts/Base.astro";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const blogCollection = await loadCollection("blog");
  const paths = [] as {
    params: { lang: string; tag: string };
    props: { posts: CollectionEntry<"blog">[] };
  }[];

  blogCollection.posts.forEach((post) => {
    const [lang] = post.id.split("/");
    post.data.tags.forEach((tag) => {
      let path = paths.find(
        (p) => p.params.lang === lang && p.params.tag === tag,
      );
      if (!path) {
        path = { params: { lang, tag }, props: { posts: [] } };
        paths.push(path);
      }
      path.props.posts.push(post);
    });
  });
  return paths;
}

const { posts } = Astro.props;
---

<Base title="BLOG">
  <div class="l-content">
    <BlogHeader />
    <BlogList {posts} />
  </div>
</Base>
