---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import { LOCALES, getLocalePaths, type Lang } from "@/i18n";
import { Font } from "astro:assets";

const locale = Astro.currentLocale as Lang;
const { title, description } = Astro.props;
---

<title>{title}</title>
<meta name="description" content={description} />

<ClientRouter />

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="sitemap" href="/sitemap-index.xml" />
{
  getLocalePaths(Astro.url).map((props) => (
    <link
      rel="alternate"
      hreflang={LOCALES[props.lang].lang || props.lang}
      href={Astro.site?.origin + props.path}
    />
  ))
}
<link
  href={import.meta.env.SITE + `/${locale}/rss.xml`}
  title="Blog Feed"
  rel="alternate"
  type="application/rss+xml"
/>

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/img/meta/favicon.svg" />
<link rel="icon" sizes="192x192" href="/img/meta/android-chrome.png" />
<link
  rel="apple-touch-icon"
  sizes="180x180"
  href="/img/meta/apple-touch-icon.png"
/>
<meta name="theme-color" content="#fb0" />
<meta name="color-scheme" content="light dark" />

<!-- Font -->
<Font cssVariable="--font-futura" preload />
{
  locale === "ja" ? (
    <Font cssVariable="--font-alibaba-jp" />
  ) : locale === "zh-cn" ? (
    <Font cssVariable="--font-alibaba-sc" />
  ) : (
    <Font cssVariable="--font-alibaba" />
  )
}

<script>
  import "@dotlottie/player-component";
  import "svg-mask-icon";
</script>
