---
import { Image } from "astro:assets";
import MeImage from "@/assets/me/eyecatch.jpg";
import SnsLink from "@/components/ui/SnsLink.astro";

const snsList = ["X", "note", "GitHub", "Instagram", "Pinterest"];
---

<section>
  <img
    class="bg"
    src="data:image/webp;base64,UklGRjAAAABXRUJQVlA4ICQAAACQAQCdASoGAAMAA4BYJaQAAp1HI1AA/tF+F7SeAIg7owAAAAA="
    alt=""
    aria-hidden="true"
  />
  <Image
    class="bg"
    id="js-fadeImage"
    data-loaded="false"
    src={MeImage}
    alt="Akira HIRATA"
  />

  <div class="l-content content">
    <h2>
      <p>Akira HIRATA</p>
      <p>is a Digital Product Designer</p>
      <p>and Web Front-end Developer.</p>
    </h2>

    <ul class="sns">
      {
        snsList.map((sns) => {
          return (
            <li>
              <SnsLink {sns} />
            </li>
          );
        })
      }
    </ul>
  </div>

  <img
    src="/img/bike.png"
    alt="roadbike illustration"
    class="bike"
    width="670"
    height="640"
  />
</section>

<script>
  document.addEventListener(
    "astro:page-load",
    () => {
      const fadeImage = document.getElementById("js-fadeImage");

      fadeImage?.setAttribute("data-loaded", "true");
      fadeImage?.addEventListener("load", () => {
        fadeImage.setAttribute("data-loaded", "true");
      });
    },
    { once: false },
  );
</script>

<style>
  #js-fadeImage {
    opacity: 0;
    transition: opacity 0.6s ease-in;
    &[data-loaded="true"] {
      opacity: 0.4;
    }
  }

  section {
    display: grid;
    height: 320px;
    margin: 16px;
    border-radius: 12px;
    overflow: hidden;
    background: #999;
    position: relative;
    font-family: var(--font-futura), sans-serif;
    @media (width < 480px) {
      height: 240px;
      margin: 0;
      border-radius: 0;
    }

    > * {
      grid-area: 1/-1;
    }

    .bg {
      width: 100%;
      height: 100%;
      min-height: 0;
      object-fit: cover;
      object-position: right;
      &:first-child {
        opacity: 0.6;
      }
      @media (width < 480px) {
        object-position: 50% center;
      }
    }

    .content {
      z-index: 1;
      margin-block: auto;
      color: #fff;
      @media (width < 480px) {
        margin-block: 8px;
      }
    }

    h2 {
      letter-spacing: 0.1em;
      font-size: 48px;
      text-shadow: 0 0 32px rgb(0 0 0 / 0.4);

      @media (width < 640px) {
        text-align: left;
      }
      @media (width < 480px) {
        font-size: 32px;
      }
      p:nth-child(2) {
        margin-block-start: 8px;
        font-size: 0.335em;
      }
      p:nth-child(3) {
        margin-block-start: 8px;
        font-size: 0.325em;
      }
    }

    .sns {
      display: flex;
      gap: 16px;
      margin-block-start: 32px;
      justify-content: center;
      @media (width < 640px) {
        justify-content: start;
      }
      @media (width < 480px) {
        gap: 20px;
        :global(a) {
          opacity: 1;
          width: 32px;
        }
      }
    }

    .bike {
      position: absolute;
      height: 160px;
      width: auto;
      bottom: -36px;
      right: 8px;
      max-width: none;
      filter: drop-shadow(0 0 16px rgb(255 255 255 / 0.2));
      animation: slidein 0.4s ease-out;

      @media (width < 640px) {
        height: 120px;
        bottom: -26px;
        right: 4px;
      }
      @media (width < 480px) {
        height: 96px;
        bottom: -20px;
        right: 0;
        filter: drop-shadow(0 0 12px rgb(255 255 255 / 0.4));
      }
    }
  }

  @keyframes slidein {
    0% {
      translate: 200px;
    }
    90% {
      translate: -10px;
    }
    100% {
      translate: 0;
    }
  }
</style>
