---
import { loadCollection } from "@/components/loadCollection.ts";
import Headline from "@/components/ui/Headline.astro";
import SnsLink from "@/components/ui/SnsLink.astro";

import { useTranslations, type Lang } from "@/i18n";

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

const followList = [
  {
    sns: "x",
    link: "https://x.com/psephopaiktes",
    title: t({ ja: "Xでフォロー", en: "Follow on X", "zh-cn": "在X上关注" }),
  },
  {
    sns: "facebook",
    link: "https://fb.me/webablog",
    title: t({
      ja: "Facebookでフォロー",
      en: "Follow on Facebook",
      "zh-cn": "在Facebook上关注",
    }),
  },
  {
    sns: "feedly",
    link: "https://feedly.com/i/subscription/feed%2Fhttps%3A%2F%2Fhira.page%2Frss.xml",
    title: t({
      ja: "Feedlyでフォロー",
      en: "Follow on Feedly",
      "zh-cn": "在Feedly上关注",
    }),
  },
  {
    sns: "rss",
    link: "https://hira.page/rss.xml",
    title: t({ ja: "RSSを表示", en: "View RSS", "zh-cn": "查看RSS" }),
  },
  {
    sns: "gnews",
    link: "https://news.google.com/publications/CAAqBwgKML_jpQswl-69Aw",
    title: t({
      ja: "Googleニュース",
      en: "Google News",
      "zh-cn": "谷歌新闻",
    }),
  },
];

const blogCollection = await loadCollection("blog", locale);
const currentTag = Astro.params.tag;
---

<header class="grid">
  <Headline label="BLOG" href={`/${locale}/blog`} class="grid1" />

  <ul class="follow grid2">
    {
      followList.map((sns) => {
        return (
          <li>
            <SnsLink sns={sns.sns} link={sns.link} title={sns.title} />
          </li>
        );
      })
    }
    <li>
      <button id="js-search">
        <svg-icon src="/img/icon/search.svg">
          {t({ ja: "検索", en: "Search", "zh-cn": "搜索" })}
        </svg-icon>
      </button>
    </li>
  </ul>

  <ul class="c-tagFilter grid3">
    {
      blogCollection.tags.map((tag) => (
        <li>
          <a
            href={
              tag == currentTag
                ? `/${locale}/blog`
                : `/${locale}/blog/tag=${tag}/`
            }
            class:list={["c-tag", tag == currentTag ? "active" : ""]}
          >
            <svg-icon src="/img/icon/tag.svg" />
            {tag}
          </a>
          <span>{blogCollection.tagCounts[tag]}</span>
        </li>
      ))
    }
  </ul>
</header>

<script>
  document.addEventListener(
    "astro:page-load",
    () => {
      const search = document.getElementById("js-search");
      search?.addEventListener("click", () => {
        const Query = prompt("search keyword");
        if (!Query) return;
        window.open(
          `https://www.google.co.jp/search?q=${Query}&as_sitesearch=hira.page`,
        );
      });
    },
    { once: false },
  );
</script>

<style lang="less">
  @import "@/styles/common.less";

  .grid {
    display: grid;
    gap: 24px;
    grid-template-areas: "grid1 grid2" "grid3 grid3";
    align-items: end;
    @media (width < @xs) {
      grid-template-areas: "grid1" "grid2" "grid3";
    }
    .grid1 {
      grid-area: grid1;
    }
    .grid2 {
      grid-area: grid2;
    }
    .grid3 {
      grid-area: grid3;
    }
  }

  .follow {
    display: flex;
    justify-content: end;
    align-items: center;
    gap: 4px;
    color: rgb(@main / 0.7);
    @media (width < @xs) {
      justify-content: start;
    }
  }

  #js-search {
    color: rgb(@label);
    margin-inline-start: 8px;
    display: block;
    height: 28px;
    svg-icon {
      aspect-ratio: 1;
      width: 28px;
    }
  }
</style>
